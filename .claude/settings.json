{
  "model": "sonnet",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Grep",
      "Glob",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git stash:*)",
      "Bash(git pull:*)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(ls *)",
      "Bash(npm install:*)",
      "Bash(npx shadcn:*)",
      "Bash(npm run:*)",
      "Bash(npx tsc:*)",
      "WebSearch",
      "WebFetch(domain:datahelpdesk.worldbank.org)",
      "WebFetch(domain:restcountries.com)",
      "WebFetch(domain:en.wikipedia.org)",
      "WebFetch(domain:population.un.org)",
      "WebFetch(domain:docs.owid.io)",
      "WebFetch(domain:adambrown.info)",
      "WebFetch(domain:www.pewresearch.org)",
      "WebFetch(domain:www.worldpopulationreview.com)",
      "WebFetch(domain:worldpopulationreview.com)",
      "WebFetch(domain:api.worldbank.org)",
      "WebFetch(domain:www.worldatlas.com)",
      "WebFetch(domain:www.everycountryintheworld.com)",
      "WebFetch(domain:objectivelists.com)",
      "WebFetch(domain:population-pyramid.net)",
      "WebFetch(domain:www.populationpyramid.net)",
      "WebFetch(domain:data.worldbank.org)",
      "WebFetch(domain:www.csis.org)",
      "WebFetch(domain:www.britannica.com)",
      "WebFetch(domain:ourworldindata.org)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(rm -rf:*)",
      "Bash(git reset --hard:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "command": "echo '[Claude Code] File modified. Run npm run lint before committing.'"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(git push:*)",
        "command": "echo '[Claude Code] Direct pushes to main are not permitted. Open a PR instead.' && exit 1"
      }
    ]
  }
}
